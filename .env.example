# ====================================
# Mission Control 配置
# ====================================

# 服务端口（默认 4000）
# PORT=4000

# 数据库文件路径（默认 ./mission-control.db）
DATABASE_PATH=./mission-control.db

# ====================================
# OpenClaw 网关
# ====================================

# OpenClaw 网关 WebSocket 地址（默认 ws://127.0.0.1:18789）
# 远程连接示例（Tailscale）：wss://your-machine.tail12345.ts.net
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# 网关鉴权令牌（远程连接时通常必填）
# 生成示例：openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# OpenClaw RPC / 任务派发调优（可选；代码侧 RPC 最短超时为 5000ms）
OPENCLAW_RPC_TIMEOUT_MS=45000
OPENCLAW_CHAT_SEND_TIMEOUT_MS=60000
OPENCLAW_DISPATCH_MAX_ATTEMPTS=3
OPENCLAW_DISPATCH_RETRY_DELAY_MS=1500

# 模型发现模式（默认 auto）
# - remote：通过已连接网关 RPC 拉取模型列表
# - local：读取本机 ~/.openclaw/openclaw.json
# - auto：先 remote，失败再用 local 与内置默认
# 网关在另一台机器上时可设为 remote
# MODEL_DISCOVERY=auto

# ====================================
# 规划（Planning）
# ====================================

# 规划单轮等待超时（毫秒，默认 30000 = 30 秒）
# 等待规划智能体（如 Charlie）回复的最长时间
PLANNING_TIMEOUT_MS=30000

# 规划轮询间隔（毫秒，默认 2000 = 2 秒）
# 规划过程中向 OpenClaw 拉取更新的频率
PLANNING_POLL_INTERVAL_MS=2000

# ====================================
# 工作区路径与 API
# ====================================

# Mission Control 自身 API 根地址（不设则自动推断）
# 远程访问或自定义部署时请覆盖
# MISSION_CONTROL_URL=http://localhost:4000

# 工作区根目录（默认 ~/Documents/Shared）
# Mission Control 相关文件默认放在此目录下
# WORKSPACE_BASE_PATH=~/Documents/Shared

# 项目/产出目录（默认 ~/Documents/Shared/projects）
# 每个任务项目对应此目录下的子文件夹
# PROJECTS_PATH=~/Documents/Shared/projects

# ====================================
# 智能体（Agent）
# ====================================

# 是否允许运行时动态创建智能体（默认 true）
# 设为 false 时仅使用已导入或手工创建的智能体，
# 规划与子智能体生成时不再自动造新 Agent
# ALLOW_DYNAMIC_AGENTS=true

# ====================================
# 安全
# ====================================

# API 访问令牌（生产环境强烈建议配置）
# 未设置时关闭鉴权（仅适合本地开发）
# 生成示例：openssl rand -hex 32
MC_API_TOKEN=

# 智能体完成回调 Webhook 的签名校验密钥
# 未设置时不校验签名（仅适合本地开发）
# 生成示例：openssl rand -hex 32
WEBHOOK_SECRET=

# ====================================
# 安全提示
# ====================================
#
# 切勿把填好真实密钥的副本提交到 Git！
# 本文件为模板，请复制为 .env.local 再按需填写：
#
#   cp .env.example .env.local
#
# 然后编辑 .env.local 写入你的实际配置。
# .env.local 已被 gitignore，不会被提交。
